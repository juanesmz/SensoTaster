   <string notr="true">QWidget#ExperimentContainer {
    background-color: #E0E0E0;
}
QLabel {
    font-family: 'Segoe UI';
}
/* Sidebar Container Style */
QWidget#sidebarContainer {
    background-color: white;
    border-radius: 15px;
    margin-top: 20px;
    margin-left: 20px;
    margin-bottom: 20px;
}

/* Button Style (shared) */
QPushButton#btnStartExperiment, QPushButton#btnPrevSection {
    background-color: #4CAF50;
    color: white;
    border-radius: 10px;
    padding: 15px;
    margin-left: 20px;
    margin-right: 20px;
    margin-top: 5px;
    margin-bottom: 5px;
    font-family: 'Segoe UI';
    font-size: 14pt;
    font-weight: bold;
    border: none;
}
QPushButton#btnStartExperiment:hover, QPushButton#btnPrevSection:hover {
    background-color: #2E7D32;
}
QPushButton#btnStartExperiment:pressed, QPushButton#btnPrevSection:pressed {
    background-color: #1B5E20;
}
QPushButton#btnStartExperiment:disabled, QPushButton#btnPrevSection:disabled {
    background-color: #A5D6A7;
    color: #E0E0E0;
}</string>
